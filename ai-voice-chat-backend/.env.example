# AI Voice Chat - Environment Variables Template

# Copy this file to .env and fill in your actual values

# ==========================================
# AI MODELS
# ==========================================

# OpenAI API Key (required for AI responses)
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Anthropic Claude API Key (for Claude models)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Google Gemini API Key (for Gemini models)
GEMINI_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ==========================================
# AUTHENTICATION
# ==========================================

# JWT Secret (for authentication)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Google OAuth (for SSO)
GOOGLE_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GOOGLE_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GOOGLE_CALLBACK_URL=http://localhost:4000/auth/google/callback

# SAML Configuration (for enterprise SSO)
SAML_ENTRY_POINT=https://your-idp.example.com/sso
SAML_ISSUER=your-organization
SAML_CERT=-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----

# ==========================================
# DATABASE
# ==========================================

# Database URL (optional, defaults to local SQLite)
DATABASE_URL=file:./dev.db

# Redis URL (optional, for caching)
REDIS_URL=redis://localhost:6379

# ==========================================
# VECTOR DATABASE (RAG)
# ==========================================

# Pinecone API Key (for vector storage)
PINECONE_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PINECONE_INDEX=ai-chat-knowledge

# ==========================================
# PAYMENT
# ==========================================

# Razorpay Payment Gateway (optional, for paid subscriptions)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# ==========================================
# SERVER CONFIG
# ==========================================

# Server Port (optional, defaults to 4000)
PORT=4000

# WebSocket Port (optional, defaults to 4001)
WS_PORT=4001

# Environment (development/production)
NODE_ENV=development

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# ==========================================
# FRONTEND ENVIRONMENT
# ==========================================

# Create in frontend/.env.local
NEXT_PUBLIC_API_URL=http://localhost:4000
