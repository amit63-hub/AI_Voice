# AI Voice Chat - Environment Variables Template

# Copy this file to .env and fill in your actual values

# OpenAI API Key (required for AI responses)
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# JWT Secret (for authentication)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Database URL (optional, defaults to local SQLite)
DATABASE_URL=file:./dev.db

# Server Port (optional, defaults to 4000)
PORT=4000

# Environment (development/production)
NODE_ENV=development

# Razorpay Payment Gateway (optional, for paid subscriptions)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# Redis URL (optional, for caching)
REDIS_URL=redis://localhost:6379

# Frontend Environment (create in frontend/.env.local)
NEXT_PUBLIC_API_URL=http://localhost:4000
